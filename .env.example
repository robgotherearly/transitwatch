# Copy this to .env and fill in your values
# Never commit .env to Git

# PostgreSQL
POSTGRES_USER=transitwatch
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=transitwatch
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=your_secret_key_here
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# MTA API — free key at https://api.mta.info/
MTA_API_KEY=your_mta_api_key_here
GTFS_REALTIME_URL=https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs
GTFS_FEED_NAME=nyc_mta

# dbt
DBT_PROFILES_DIR=/opt/airflow/dbt
