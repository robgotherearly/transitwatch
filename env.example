# Copy this to .env and fill in your values
# Never commit .env to Git

# PostgreSQL
POSTGRES_USER=transitwatch
POSTGRES_PASSWORD=transitwatch_dev
POSTGRES_DB=transitwatch
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=your_secret_key_here
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# GTFS Feed — free public feed (London Buses)
# Swap this URL for any city: https://transitfeeds.com
GTFS_REALTIME_URL=https://api.tfl.gov.uk/gtfs/trip-updates
GTFS_FEED_NAME=london_buses

# dbt
DBT_PROFILES_DIR=/opt/airflow/dbt
